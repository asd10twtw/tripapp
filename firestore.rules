rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "asd10twtw@gmail.com" && request.auth.token.email_verified == true);
    }

    function canAccessTrip(tripId) {
      let trip = get(/databases/$(database)/documents/trips/$(tripId)).data;
      return isAuthenticated() && (request.auth.uid in trip.memberUids || isAdmin());
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /trips/{tripId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.memberUids || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid in resource.data.memberUids || isAdmin());

      // Sub-collections
      match /{allSubcollections=**} {
        allow read, write: if canAccessTrip(tripId);
      }
    }

    // Legacy Collections (for migration)
    match /events/{id} { allow read, delete: if isAuthenticated(); }
    match /expenses/{id} { allow read, delete: if isAuthenticated(); }
    match /todos/{id} { allow read, delete: if isAuthenticated(); }
    match /journal/{id} { allow read, delete: if isAuthenticated(); }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
